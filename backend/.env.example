# Nomba account scoping
NOMBA_ACCOUNT_ID=
NOMBA_SUBACCOUNT_ID=

# Nomba API auth — use the TEST client_id/private_key pair for all
# development, the July 3 checkpoint, and ideally the whole build
# through the demo.
#
# CORRECTED: the training-certification material's
# https://sandbox.api.nomba.com/v1 is NOT A REAL DOMAIN — it does not
# resolve via DNS at all (confirmed against two independent
# resolvers). The real sandbox host, per Nomba's actual official
# developer docs (developer.nomba.com), is https://sandbox.nomba.com
# — no "api." subdomain. Production is unaffected: https://api.nomba.com.
#   Sandbox (all hackathon work):  https://sandbox.nomba.com/v1
#   Production (post-KYC only):    https://api.nomba.com/v1
NOMBA_CLIENT_ID=
NOMBA_PRIVATE_KEY=
NOMBA_API_BASE_URL=https://sandbox.nomba.com/v1

# Webhook verification — CRITICAL CORRECTION. The signature is NOT a
# hash of the raw request body — it's a base64-encoded HMAC-SHA256
# over nine specific colon-joined fields (event_type, requestId,
# merchant.userId, merchant.walletId, transaction.transactionId,
# transaction.type, transaction.time, transaction.responseCode, and
# the nomba-timestamp HEADER value), confirmed directly against
# developer.nomba.com's reference implementations in six languages.
# An earlier version of this system hashed the raw body and used hex
# encoding — that construction would have rejected every genuine
# webhook as a signature mismatch. See services/signature.py for the
# full algorithm and citation. NOMBA_TIMESTAMP_HEADER is not just
# informational — it's an actual input to the hash.
NOMBA_WEBHOOK_SIGNATURE_KEY=
NOMBA_SIGNATURE_HEADER=nomba-signature
NOMBA_TIMESTAMP_HEADER=nomba-timestamp

# AI — Gemini is tried first, Groq only if Gemini is unconfigured or
# its call fails. Both are optional; if neither is set, the system
# falls back to plain deterministic template messages, and webhook
# ingestion is never blocked by an AI provider being down.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# App
DATABASE_URL=sqlite:///./nombareclaim.db
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app
FRONTEND_BASE_URL=http://localhost:5173

RECOVERY_SCORE_THRESHOLD=60
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60

# Webhook event type names — genuinely unconfirmed by any doc source
# seen so far (see routes/webhooks.py). Confirm the real name against
# Nomba's webhook-registration event picker or a live sandbox test,
# then update here — no code change or redeploy needed either way.
NOMBA_FAILURE_EVENT_TYPES=PAYMENT_FAILED
NOMBA_SUCCESS_EVENT_TYPES=PAYMENT_SUCCESS

# Automated recovery (email). OFF by default on purpose — a fresh
# deploy should never silently email a real customer until someone
# deliberately turns this on. When enabled, only fires for events that
# (a) have a customer_email captured from the webhook payload and
# (b) clear AUTO_RECOVERY_MIN_SCORE.
RECOVERY_AUTOMATION_ENABLED=false
AUTO_RECOVERY_MIN_SCORE=40

# Follow-up retry scheduling ("payday retry" for insufficient-funds
# failures, fixed backoff for everything else). See
# services/scheduling.py for exactly how these are used.
PAYDAY_RETRY_DAYS=25,26,27,28,29,30,31,1
RETRY_BACKOFF_HOURS=3,24,72
MAX_AUTO_RETRIES=3
RETRY_SWEEP_INTERVAL_SECONDS=300

# Outbound email (SMTP). Works with a Gmail app password, Zoho, or any
# SMTP relay. Leave blank to keep automation fully inert even if
# RECOVERY_AUTOMATION_ENABLED=true — send_recovery_email logs and
# returns False rather than raising when unconfigured.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=NombaReclaim
